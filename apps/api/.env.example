# Copy to .env and fill in real values. Never commit .env.
PORT=4000
NODE_ENV=development

# Postgres connection string (Neon, local, or any Postgres provider)
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# Comma-separated allowed frontend origins in production, e.g.
# "https://apexpay.example,https://admin.apexpay.example". Leave unset in development — main.ts
# falls back to a fixed localhost/tunnel allowlist instead.
CORS_ORIGINS=

# Auth — generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_ACCESS_SECRET=
JWT_ACCESS_TTL=15m
REFRESH_TOKEN_TTL_DAYS=30

# 32-byte hex key for column-level encryption (KYC IDs, bank details).
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=

# Keyed hash pepper for OTP codes — must differ from ENCRYPTION_KEY.
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
OTP_HMAC_SECRET=
OTP_TTL_MINUTES=10
OTP_MAX_ATTEMPTS=5
OTP_REQUEST_COOLDOWN_SECONDS=60
OTP_REQUEST_MAX_PER_WINDOW=5
OTP_REQUEST_WINDOW_MINUTES=60

# Email OTP delivery — interim channel while SMS delivery is unavailable. EmailModule prefers
# AWS SES (if AWS_SES_ACCESS_KEY_ID is set) over Resend (if RESEND_API_KEY is set) over logging
# codes to the console in development. Leaving both unset in production is a fatal boot error.
# EMAIL_FROM must be a sender address verified with whichever provider is actually active.
RESEND_API_KEY=
AWS_SES_ACCESS_KEY_ID=
AWS_SES_SECRET_ACCESS_KEY=
AWS_SES_REGION=us-east-1
EMAIL_FROM="APEX PAY <onboarding@resend.dev>"

# Single platform-wide pot/collection account shown to payers. Replace with the real
# business bank account before any real money moves (plan §2 — never a personal account).
POT_ACCOUNT_BANK_NAME="Apex Pay Collections (Test Bank)"
POT_ACCOUNT_NUMBER=1234567890
POT_ACCOUNT_NAME="Apex Pay Ltd"

# Signing secret for proof-of-payment file access tokens (dev-local-disk storage only).
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
FILE_ACCESS_HMAC_SECRET=
