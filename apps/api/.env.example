# Copy to .env and fill in real values. Never commit .env.
PORT=4000
NODE_ENV=development

# Postgres connection string (Neon, local, or any Postgres provider)
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# Auth — generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_ACCESS_SECRET=
JWT_ACCESS_TTL=15m
REFRESH_TOKEN_TTL_DAYS=30

# 32-byte hex key for column-level encryption (KYC IDs, bank details).
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=

# Keyed hash pepper for OTP codes — must differ from ENCRYPTION_KEY.
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
OTP_HMAC_SECRET=
OTP_TTL_MINUTES=10
OTP_MAX_ATTEMPTS=5
OTP_REQUEST_COOLDOWN_SECONDS=60
OTP_REQUEST_MAX_PER_WINDOW=5
OTP_REQUEST_WINDOW_MINUTES=60
