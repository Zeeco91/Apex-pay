// Apex Pay — Prisma schema
// Domain models are added incrementally, phase by phase, per the implementation plan
// (C:\Users\emmanuel\.claude\plans\this-all-is-the-humming-gizmo.md, section 3).
// Phase 3 (Auth & Identity) added: User, KycRecord, OtpCode, RefreshToken.
// Phase 4 (Levels & Dashboard skeleton) added: Level.
// Phase 5 (Queue & Matching Engine) added: QueueEntry, Transaction.
// Phase 6 (Pooled Payment Flow) added: TreasuryLedgerEntry, TreasuryBalance.
// Phase 7 (Referral Program & Level Incentive Bonus) added: FeePool, PublicHoliday,
// ReferralBonus, LevelIncentiveBonus, WithdrawalRequest.
// Phase 8 (Admin Panel Core) adds: AdminAuditLog.
// Phase 9 (Admin Reporting & Treasury Reconciliation) adds: ReconciliationRun.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  SUPPORT
  ADMIN
  SUPER_ADMIN
}

enum UserStatus {
  // KYC has been removed as a product requirement (no more identity-verification gate on
  // queue participation). PENDING_KYC is kept as a dead value rather than dropped, since
  // removing a Postgres enum value in place requires recreating the type — not worth the risk
  // for a value nothing writes anymore. New users default straight to ACTIVE.
  PENDING_KYC
  ACTIVE
  SUSPENDED
  BANNED
}

enum OtpPurpose {
  REGISTER
  LOGIN_STEP_UP
  PIN_RESET
}

enum QueueEntryStatus {
  PENDING_JOIN_PAYMENT
  WAITING_FOR_PAYOUT
  MATCHED_AS_PAYEE
  COMPLETED
  CANCELLED
  ADMIN_HOLD
}

enum TransactionStatus {
  AWAITING_PAYER_PROOF
  PROOF_SUBMITTED
  PRINCIPAL_RECEIVED
  PENDING_DISBURSEMENT
  DISBURSED
  CONFIRMED
  DISPUTED
  ADMIN_RESOLVED_CONFIRMED
  ADMIN_RESOLVED_REJECTED
  CANCELLED
}

enum MatchType {
  AUTOMATIC_FIFO
  MANUAL_ADMIN
}

// Full documented shape (plan §3) declared now even though phase 6 only ever writes
// PRINCIPAL_COLLECTED / FEE_COLLECTED / DISBURSED — the FEE_ALLOCATED_* and *_PAID types are
// written starting in the Referral Program phase (plan §9 step 7) once FeePool exists.
enum TreasuryEntryType {
  PRINCIPAL_COLLECTED
  DISBURSED
  FEE_COLLECTED
  FEE_ALLOCATED_REFERRAL_POOL
  FEE_ALLOCATED_INCENTIVE_POOL
  FEE_ALLOCATED_PLATFORM_REVENUE
  REFERRAL_BONUS_PAID
  LEVEL_INCENTIVE_BONUS_PAID
  PLATFORM_REVENUE_WITHDRAWN
}

enum FeePoolType {
  REFERRAL
  LEVEL_INCENTIVE
}

enum ReferralBonusStatus {
  HOLD
  ELIGIBLE_FOR_WITHDRAWAL
  WITHDRAWN
  FORFEITED
}

enum LevelIncentiveBonusStatus {
  PAID_IN_FULL
  PARTIALLY_PAID
  SKIPPED_INSUFFICIENT_POOL
}

enum WithdrawalType {
  REFERRAL_BONUS
}

enum WithdrawalRequestStatus {
  PENDING
  APPROVED
  REJECTED
  PAID
}

enum AdminActionType {
  USER_SUSPENDED
  USER_BANNED
  USER_REINSTATED
  // KYC has been removed as a feature — these two values are kept only so historical
  // AdminAuditLog rows from when KYC review existed keep resolving to a valid enum value.
  // Nothing writes them anymore.
  KYC_APPROVED
  KYC_REJECTED
  QUEUE_ENTRY_HELD
  QUEUE_ENTRY_RELEASED
  QUEUE_MANUAL_MATCH
  LEVEL_UPDATED
  TRANSACTION_PRINCIPAL_CONFIRMED
  TRANSACTION_DISBURSED
  TRANSACTION_DISPUTE_RESOLVED
  WITHDRAWAL_APPROVED
  WITHDRAWAL_REJECTED
  WITHDRAWAL_PAID
  PUBLIC_HOLIDAY_ADDED
  PUBLIC_HOLIDAY_REMOVED
  SUPPORT_CONVERSATION_RESOLVED
}

enum SupportConversationStatus {
  OPEN
  RESOLVED
}

enum SupportMessageSenderRole {
  USER
  ADMIN
}

model User {
  id                 String     @id @default(uuid())
  phone              String     @unique
  phoneVerifiedAt    DateTime?
  // Nullable because 113 accounts already existed when this was added (no backfill value would
  // be meaningful) — every new registration requires one (enforced in RegisterDto), used as the
  // OTP delivery address while SMS delivery is unavailable (plan: swap back once SMS is fixed).
  email              String?    @unique
  fullName           String
  pinHash            String
  referralCode       String     @unique
  referredByUserId   String?
  referredBy         User?      @relation("Referrals", fields: [referredByUserId], references: [id])
  referrals          User[]     @relation("Referrals")
  role               UserRole   @default(USER)
  status             UserStatus @default(ACTIVE)
  payoutBankDetails  Json?
  deviceFingerprints Json?
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt
  lastLoginAt        DateTime?

  // Brute-force protection on PIN login (plan §10 hardening) — a 4-digit PIN is a small
  // keyspace, so per-account lockout backs up the per-IP throttle on the login route.
  failedPinAttempts Int       @default(0)
  pinLockedUntil    DateTime?

  // TOTP-based MFA (plan §10: "MFA enforcement" for the admin trust model). Enforced for
  // ADMIN/SUPER_ADMIN via RolesGuard — see mfa.service.ts and roles.guard.ts.
  mfaSecret  String?
  mfaEnabled Boolean @default(false)

  refreshTokens RefreshToken[]
  queueEntries  QueueEntry[]

  transactionsAsPayer Transaction[] @relation("TransactionsAsPayer")
  transactionsAsPayee Transaction[] @relation("TransactionsAsPayee")

  // A user can refer many people, but can only ever BE referred once (enforced by the
  // @unique on ReferralBonus.referredUserId — this is a to-one relation from that side).
  referralBonusesGiven  ReferralBonus[]       @relation("ReferralBonusReferrer")
  referralBonusReceived ReferralBonus?        @relation("ReferralBonusReferred")
  levelIncentiveBonuses LevelIncentiveBonus[]
  withdrawalRequests    WithdrawalRequest[]
  adminAuditLogs        AdminAuditLog[]

  // A user's single ongoing support thread (created lazily on first message) plus every
  // message they've personally sent, whether as the USER side of their own conversation or
  // as the ADMIN replying into someone else's — see SupportMessage.senderId.
  supportConversation SupportConversation?
  supportMessagesSent SupportMessage[]

  @@index([status])
}

model OtpCode {
  id           String     @id @default(uuid())
  phone        String
  purpose      OtpPurpose
  codeHash     String
  expiresAt    DateTime
  consumedAt   DateTime?
  attemptCount Int        @default(0)
  ipAddress    String?
  createdAt    DateTime   @default(now())

  @@index([phone, purpose])
}

model RefreshToken {
  id         String    @id @default(uuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id])
  tokenHash  String    @unique
  deviceInfo String?
  ipAddress  String?
  createdAt  DateTime  @default(now())
  expiresAt  DateTime
  revokedAt  DateTime?

  @@index([userId])
}

// Contribution tiers. Rows are seeded/managed by an operator today (prisma/seed.ts);
// an admin CRUD surface over this table is planned for the Admin Panel Core phase (plan §9 step 8).
// The three *PercentOfFee fields must sum to 100 for a given row — enforced in LevelsService,
// not the DB, since Postgres has no portable "sum of sibling columns" constraint.
model Level {
  id                                  String   @id @default(uuid())
  name                                String
  contributionAmount                  Int
  feePercent                          Float    @default(5)
  referralPoolAllocationPercentOfFee  Float
  incentivePoolAllocationPercentOfFee Float
  platformRevenuePercentOfFee         Float
  incentiveBonusRateOfPrincipal       Float
  stalledThresholdDays                Int      @default(14)
  isActive                            Boolean  @default(true)
  sortOrder                           Int      @unique
  createdAt                           DateTime @default(now())
  updatedAt                           DateTime @updatedAt

  queueEntries          QueueEntry[]
  transactions          Transaction[]
  referralBonuses       ReferralBonus[]
  levelIncentiveBonuses LevelIncentiveBonus[]

  @@index([isActive, sortOrder])
}

// One row per member currently (or previously) waiting in a level's FIFO payout queue.
// See QueueService for the join/match/cancel state machine (plan §4).
model QueueEntry {
  id            String           @id @default(uuid())
  userId        String
  user          User             @relation(fields: [userId], references: [id])
  levelId       String
  level         Level            @relation(fields: [levelId], references: [id])
  queueSequence Int              @default(autoincrement())
  status        QueueEntryStatus @default(WAITING_FOR_PAYOUT)

  // Denormalized for fast lookup in either direction — kept in sync by QueueService inside the
  // same DB transaction that creates the Transaction. Not FK-enforced: the authoritative
  // relation lives on Transaction.payerQueueEntryId / payeeQueueEntryId below.
  outgoingTransactionId String?
  incomingTransactionId String?

  joinedAt            DateTime  @default(now())
  payoutDueEstimateAt DateTime?
  completedAt         DateTime?
  cancelledAt         DateTime?
  adminNotes          String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // One-to-many: a QueueEntry that gets unmatched (payer cancels before paying) and later
  // re-matched accumulates more than one Transaction over its lifetime — only the most recent
  // is "active". QueueService resolves "the current one" via outgoing/incomingTransactionId
  // above rather than these relations, which exist for completeness/admin queries.
  transactionsAsPayer Transaction[] @relation("PayerQueueEntry")
  transactionsAsPayee Transaction[] @relation("PayeeQueueEntry")

  @@index([levelId, status, queueSequence])
  @@index([userId])
}

// A matched payer/payee pair within one level. Created the instant FIFO matching pairs a new
// joiner with the oldest waiting member; the pooled payment flow (proof, disbursement, dispute)
// that advances status past AWAITING_PAYER_PROOF is built in a later phase (plan §9 step 6).
model Transaction {
  id      String @id @default(uuid())
  levelId String
  level   Level  @relation(fields: [levelId], references: [id])

  // Not unique: the same QueueEntry can be the payee of successive Transactions over its
  // lifetime (matched -> payer cancels before paying -> unmatched -> matched again).
  payerQueueEntryId String
  payerQueueEntry   QueueEntry @relation("PayerQueueEntry", fields: [payerQueueEntryId], references: [id])
  payeeQueueEntryId String
  payeeQueueEntry   QueueEntry @relation("PayeeQueueEntry", fields: [payeeQueueEntryId], references: [id])

  payerUserId String
  payerUser   User   @relation("TransactionsAsPayer", fields: [payerUserId], references: [id])
  payeeUserId String
  payeeUser   User   @relation("TransactionsAsPayee", fields: [payeeUserId], references: [id])

  principalAmount      Int
  platformFeeAmount    Int
  payeeDisbursedAmount Int

  matchType MatchType         @default(AUTOMATIC_FIFO)
  status    TransactionStatus @default(AWAITING_PAYER_PROOF)

  payerProofImageKey          String?
  payerProofUploadedAt        DateTime?
  principalReceivedAt         DateTime?
  principalConfirmedByAdminId String?

  payeeBankDetailsSnapshot Json?
  disbursedAt              DateTime?
  disbursedByAdminId       String?
  disbursementReference    String?
  disbursementProofKey     String?
  payeeConfirmedAt         DateTime?

  disputeReason          String?
  disputeRaisedByUserId  String?
  disputeRaisedAt        DateTime?
  adminResolutionNotes   String?
  adminResolvedByAdminId String?
  adminResolvedAt        DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  ledgerEntries            TreasuryLedgerEntry[]
  // Not to-one: a single transaction can trigger a ReferralBonus for BOTH parties at once
  // (payer and payee are each checked independently in TransactionsService.confirmReceipt),
  // so this is a list even though any one transaction rarely produces more than one.
  triggeredReferralBonuses ReferralBonus[]
  triggeredIncentiveBonus  LevelIncentiveBonus?

  @@index([levelId, status])
  @@index([payerUserId])
  @@index([payeeUserId])
  @@index([payerQueueEntryId])
  @@index([payeeQueueEntryId])
}

// Append-only reconciliation source of truth (plan §2, §3) — running pot balance must match
// the real bank account. Every entry is written inside the same DB transaction as the state
// change that caused it, alongside an atomic update to TreasuryBalance below.
model TreasuryLedgerEntry {
  id                   String            @id @default(uuid())
  entryType            TreasuryEntryType
  amount               Int
  relatedTransactionId String?
  relatedTransaction   Transaction?      @relation(fields: [relatedTransactionId], references: [id])
  balanceAfter         Int
  createdAt            DateTime          @default(now())

  @@index([entryType, createdAt])
  @@index([relatedTransactionId])
}

// Singleton running-balance counter (always id=1, seeded by prisma/seed.ts). Updated via an
// atomic `increment` inside the same DB transaction as each TreasuryLedgerEntry write — this is
// what makes balanceAfter race-safe under concurrent disbursements without a table-level lock.
model TreasuryBalance {
  id      Int @id @default(1)
  balance Int @default(0)
}

// Two rows (REFERRAL, LEVEL_INCENTIVE), seeded by prisma/seed.ts. currentBalance is the
// earmarked sub-account within the pot that's actually available to pay out for that purpose —
// it is credited via FEE_ALLOCATED_* ledger entries at disbursement (TransactionsService.disburse)
// and debited when a bonus is actually paid. Reads/writes to currentBalance for payout decisions
// MUST happen under a row lock (`SELECT ... FOR UPDATE`) in the same DB transaction as the
// deduction — see TransactionsService for why (plan §5a: two concurrent disbursements must not
// double-spend the same pool balance).
model FeePool {
  id                     String      @id @default(uuid())
  poolType               FeePoolType @unique
  currentBalance         Int         @default(0)
  totalAllocatedLifetime Int         @default(0)
  totalPaidLifetime      Int         @default(0)
  updatedAt              DateTime    @updatedAt
}

// One row per reconciliation pass (daily cron + on-demand admin trigger). Recomputes each
// balance from its ledger history independently of the running counters (TreasuryBalance.balance,
// FeePool.currentBalance) and records any drift — the running counters are updated atomically
// alongside every ledger write, so in a healthy system drift should always be zero; a nonzero
// value here is the signal that something (a bug, a manual DB edit) broke that invariant.
model ReconciliationRun {
  id                      String                @id @default(uuid())
  runAt                   DateTime              @default(now())
  treasuryBalanceExpected Int
  treasuryBalanceActual   Int
  treasuryDrift           Int
  referralPoolExpected    Int
  referralPoolActual      Int
  referralPoolDrift       Int
  incentivePoolExpected   Int
  incentivePoolActual     Int
  incentivePoolDrift      Int
  hasDiscrepancy          Boolean
  triggeredBy             ReconciliationTrigger

  @@index([runAt])
}

enum ReconciliationTrigger {
  SCHEDULED
  MANUAL
}

// Maintained calendar for the referral bonus hold period's "30 working days" calculation
// (plan §5). Seeded with a starter set of Nigerian public holidays; a real admin-editable
// surface arrives with the Admin Panel Core phase.
model PublicHoliday {
  id   String   @id @default(uuid())
  date DateTime @unique @db.Date
  name String

  @@index([date])
}

// One row per referred user, ever (enforced by @unique below) — created the instant that
// referred user's own first Transaction reaches CONFIRMED (plan §5, "not just at sign-up").
// The referrer only ever gets rewarded for a genuinely-participating referral, not a signup.
model ReferralBonus {
  id             String @id @default(uuid())
  referrerUserId String
  referrerUser   User   @relation("ReferralBonusReferrer", fields: [referrerUserId], references: [id])
  referredUserId String @unique
  referredUser   User   @relation("ReferralBonusReferred", fields: [referredUserId], references: [id])

  triggerTransactionId String
  triggerTransaction   Transaction @relation(fields: [triggerTransactionId], references: [id])
  levelId              String
  level                Level       @relation(fields: [levelId], references: [id])

  // bonusAmount = triggerTransaction.platformFeeAmount * level.referralPoolAllocationPercentOfFee
  // — always derived from fee revenue actually collected on this one transaction, never from
  // any user's principal. Not capped against FeePool[REFERRAL].currentBalance at creation time
  // (unlike LevelIncentiveBonus) — availability is an admin judgment call made at withdrawal
  // approval, informed by GET /admin/fee-pools, since payout only happens after a 30-working-day
  // hold anyway and the pool has time to accumulate.
  grossFeeAmount Int
  bonusAmount    Int

  status          ReferralBonusStatus @default(HOLD)
  holdStartedAt   DateTime            @default(now())
  holdReleaseAt   DateTime
  withdrawnAt     DateTime?
  forfeitedAt     DateTime?
  forfeitedReason String?

  withdrawalRequest WithdrawalRequest?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([referrerUserId, status])
  @@index([status, holdReleaseAt])
}

// One row per (payee, disbursed transaction) where the level offers a nonzero incentive rate —
// created inside the same DB transaction as TransactionsService.disburse. paidAmount can be less
// than entitlementAmount (or zero) if FeePool[LEVEL_INCENTIVE] can't cover it — see plan §5a.
// This is intentionally variable, never guaranteed; UI copy must say "up to X%", never "get X%".
model LevelIncentiveBonus {
  id      String @id @default(uuid())
  userId  String
  user    User   @relation(fields: [userId], references: [id])
  levelId String
  level   Level  @relation(fields: [levelId], references: [id])

  triggerTransactionId String      @unique
  triggerTransaction   Transaction @relation(fields: [triggerTransactionId], references: [id])

  entitlementAmount Int
  paidAmount        Int
  status            LevelIncentiveBonusStatus
  poolBalanceBefore Int
  poolBalanceAfter  Int

  createdAt DateTime @default(now())

  @@index([userId])
}

// A referral bonus payout request, raised by the referrer once their ReferralBonus is
// ELIGIBLE_FOR_WITHDRAWAL. Admin-gated approve/reject/mark-paid flow (no UI yet — see
// AdminReferralsController) mirrors the disbursement confirm-then-pay pattern from phase 6.
model WithdrawalRequest {
  id     String         @id @default(uuid())
  userId String
  user   User           @relation(fields: [userId], references: [id])
  amount Int
  type   WithdrawalType @default(REFERRAL_BONUS)

  referralBonusId String        @unique
  referralBonus   ReferralBonus @relation(fields: [referralBonusId], references: [id])

  bankDetailsSnapshot Json
  status              WithdrawalRequestStatus @default(PENDING)
  reviewedByAdminId   String?
  reviewedAt          DateTime?
  rejectionReason     String?
  paymentReference    String?
  paidAt              DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, status])
  @@index([status])
}

// Immutable-by-convention record of every discretionary/adverse admin action (plan §7:
// "every admin mutation logged... nothing happens without an audit trail"). No PATCH/DELETE
// endpoint is ever exposed for this model — true DB-level append-only enforcement (REVOKE
// UPDATE/DELETE) needs a dedicated DB role this single-connection-string setup doesn't have;
// documented gap, not silently pretended-away.
model AdminAuditLog {
  id               String          @id @default(uuid())
  adminUserId      String
  adminUser        User            @relation(fields: [adminUserId], references: [id])
  actionType       AdminActionType
  targetEntityType String
  targetEntityId   String
  reason           String
  beforeState      Json?
  afterState       Json?
  ipAddress        String?
  createdAt        DateTime        @default(now())

  @@index([targetEntityType, targetEntityId])
  @@index([adminUserId, createdAt])
}

// One persistent support thread per user (the "personal chatroom" — plan phase 11), created
// lazily on that user's first message. lastMessage* fields are a deliberate denormalization:
// they let the admin inbox list render (including per-row "unread" state) without an N+1 query
// or a per-row COUNT — SupportChatService keeps them in sync inside the same transaction as
// every SupportMessage insert. Unread is derived, not stored as a counter, to avoid drift:
// unread-for-admin = lastMessageSenderRole is USER and lastMessageAt is after adminLastReadAt.
model SupportConversation {
  id     String @id @default(uuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id])

  status SupportConversationStatus @default(OPEN)

  lastMessageAt         DateTime                 @default(now())
  lastMessagePreview    String
  lastMessageSenderRole SupportMessageSenderRole

  // Null adminLastReadAt means no admin has ever opened this conversation yet.
  userLastReadAt  DateTime  @default(now())
  adminLastReadAt DateTime?

  resolvedByAdminId String?
  resolvedAt        DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  messages SupportMessage[]

  @@index([status, lastMessageAt])
}

model SupportMessage {
  id             String              @id @default(uuid())
  conversationId String
  conversation   SupportConversation @relation(fields: [conversationId], references: [id])
  senderId       String
  sender         User                @relation(fields: [senderId], references: [id])

  // Snapshot at send time rather than derived from sender.role — a user's role never changes
  // in practice, but this keeps message history stable even if it did, and avoids a join.
  senderRole SupportMessageSenderRole
  body       String

  createdAt DateTime @default(now())

  @@index([conversationId, createdAt])
}
